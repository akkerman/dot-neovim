{
  "Class": {
    "prefix": ["cls"],
    "body": [
      "/**",
      " * @author ${VIM:\\$USER}",
      " */",
      "class $1 ${2:extends ${3:Parent} }{",
      "\tconstructor() {",
      "\t\t$0",
      "\t}",
      "}"
    ],
    "description": "Class definition template."
  }, 
  "MakeRequire": {
      "prefix": ["makerequire", "mreq", "testmake"],
      "body": [
        "const make${1:FunctionUnderTest} = require('./${2:$TM_FILENAME_BASE}')",
        "",
        "describe('test ${2}', () => {",
        "  let deps",
        "",
        "  beforeEach(() => {",
        "    jest.clearAllMocks()",
        "",
        "    deps = {",
        "      ${3:dependantFunction}: jest.fn().mockResolvedValue(null),",
        "    }",
        "  })",
        "",
        "  describe('make${1:FunctionUnderTest}', () => {",
        "    it.each([",
        "      null, undefined, {}",
        "    ])('requires input', input => {",
        "      expect(() => make${1}(input)).toThrow()",
        "    })",
        "",
        "    it.each([",
        "      ['${3}', 'function'],",
        "      $0",
        "    ])('requires a %s', (dep, type) => {",
        "      const expectedError = `make${1} requires \\${dep} \\${type}`",
        "",
        "      expect(() => make${1}({ ...deps, [dep]: undefined })).toThrow(expectedError)",
        "    })",
        "  })",
        "",
        "  describe('${4:$1}', () => {",
        "    let ${4}",
        "",
        "    beforeEach(() => {",
        "      ${4} = make${1}(deps)",
        "    })",
        "    it('does not throw', async () => {",
        "      const result = await ${4}()",
        "      expect(result).toBeDefined()",
        "    })",
        "  })",
        "})"
      ],
      "description": "Test template for make functions"
  }
}
